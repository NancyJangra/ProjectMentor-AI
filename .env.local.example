# Copy this file to .env.local and fill in real values.
# .env.local is never committed to git (see .gitignore) — it stays on your machine only.

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase project URL and keys.
# Create a free project at https://supabase.com, then open
# Project Settings → API to find these values.
#
# NEXT_PUBLIC_ prefix makes these two visible to the browser (required for
# Supabase Auth / OAuth sign-in flows). The service role key must NOT have
# this prefix — it is only ever used server-side and should stay secret.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# One-time database setup:
#   1. In the Supabase SQL Editor, run supabase/schema.sql
#      (creates the projects table, pgvector index, and match_projects function).
#   2. Then run supabase/add-auth.sql
#      (adds the user_id column, RLS policies, and updates match_projects
#      to filter per user — required before anyone can sign in).
#
# OAuth providers (Google and GitHub):
#   In Supabase dashboard → Authentication → Providers, enable Google and
#   GitHub and paste in the client ID + secret from each provider's console.
#   Set the callback URL to: https://<your-domain>/auth/callback
#   (for local development: http://localhost:3000/auth/callback)
